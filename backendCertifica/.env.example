# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Credenciais do PostgreSQL
POSTGRES_USER=certifica
POSTGRES_PASSWORD=certifica_secret
POSTGRES_DB=certifica_db

# String de conexão usada pelo FastAPI e pelo Alembic
# Para rodar com Docker: use o hostname 'db' (nome do serviço no docker-compose)
# Para rodar localmente: use 'localhost'
DATABASE_URL=postgresql+asyncpg://certifica:certifica_secret@localhost:5432/certifica_db
